APP_NAME=ProductCommunityAPI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=product_community
DB_USERNAME=root
DB_PASSWORD=
MYSQL_ATTR_SSL_CA=
MYSQL_ATTR_SSL_CAPATH=
MYSQL_ATTR_SSL_CERT=
MYSQL_ATTR_SSL_KEY=
MYSQL_ATTR_SSL_VERIFY_SERVER_CERT=true

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
COMMUNITY_UPLOAD_DISK=s3
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
FRONTEND_URL=http://localhost:3000
FRONTEND_PASSWORD_RESET_PATH=/reset-password
FRONTEND_EMAIL_VERIFICATION_PATH=/email-verified
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_PER_PAGE=20
API_MAX_PER_PAGE=50
IDEA_MEDIA_DIRECTORY=ideas
IDEA_MEDIA_MAX_FILES=12
IDEA_MEDIA_MAX_EXTERNAL_LINKS=4
IDEA_MEDIA_MAX_FILE_SIZE_KB=10240
IDEA_MEDIA_ALLOWED_EXTENSIONS=jpg,jpeg,png,webp,gif,pdf,doc,docx,ppt,pptx,xls,xlsx
IDEA_MEDIA_IMAGE_EXTENSIONS=jpg,jpeg,png,webp,gif
IDEA_MEDIA_DOCUMENT_EXTENSIONS=pdf,doc,docx,ppt,pptx,xls,xlsx

VITE_APP_NAME="${APP_NAME}"
